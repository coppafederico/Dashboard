{
  "name": "dashboard-example",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win portable",
    "build:linux": "electron-builder --linux AppImage",
    "build:mac": "electron-builder --mac dmg",
    "build:all": "electron-builder --win portable --linux AppImage"
  },
  "build": {
    "appId": "com.formula.dashboard",
    "productName": "Formula Dashboard",
    "asar": true,
    "win": {
      "target": "portable"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.0.12"
  }
}